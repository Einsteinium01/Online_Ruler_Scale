---
---

<button
	type="button"
	data-theme-toggle
	class="toolbar-btn"
	title="Toggle dark mode"
	aria-label="Toggle dark mode"
>
	<svg data-icon-sun viewBox="0 0 16 16" width="15" height="15" fill="none" class="hidden dark:block" aria-hidden="true">
		<circle cx="8" cy="8" r="3.25" stroke="currentColor" stroke-width="1.3" />
		<path
			d="M8 1v1.5M8 13.5V15M15 8h-1.5M2.5 8H1M12.8 3.2l-1.05 1.05M4.25 11.75L3.2 12.8M12.8 12.8l-1.05-1.05M4.25 4.25L3.2 3.2"
			stroke="currentColor"
			stroke-width="1.3"
			stroke-linecap="round"
		/>
	</svg>
	<svg data-icon-moon viewBox="0 0 16 16" width="15" height="15" fill="none" class="dark:hidden" aria-hidden="true">
		<path
			d="M14 9.1A6 6 0 116.9 2a4.6 4.6 0 007.1 7.1z"
			stroke="currentColor"
			stroke-width="1.3"
			stroke-linejoin="round"
		/>
	</svg>
</button>

<style>
	.toolbar-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: var(--radius-pill);
		color: var(--color-body);
	}
	.toolbar-btn:hover {
		background-color: var(--color-canvas-soft-2);
		color: var(--color-ink);
	}
</style>

<script>
	import { toggleTheme } from '../../lib/theme';

	const button = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
	button?.addEventListener('click', () => toggleTheme());

	function isTypingTarget(target: EventTarget | null): boolean {
		const el = target as HTMLElement | null;
		return !!el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable);
	}

	// "d" toggles dark mode on every page (ThemeToggle renders sitewide via Nav).
	window.addEventListener('keydown', (e) => {
		if (e.key !== 'd' && e.key !== 'D') return;
		if (e.metaKey || e.ctrlKey || e.altKey) return;
		if (isTypingTarget(e.target)) return;
		toggleTheme();
	});
</script>
