---
const year = 2026;
---

<footer class="border-t border-hairline bg-canvas px-4 py-16 text-body-sm text-body md:px-6 md:py-24">
	<div class="container-page">
		<div class="flex flex-col gap-10 md:flex-row md:justify-between">
			<div class="max-w-sm">
				<p class="text-body-sm font-medium text-ink">Online Ruler Scale</p>
				<p class="mt-2 text-body-sm text-mute">
					A free, calibrated on-screen ruler that measures real objects to actual size.
				</p>
			</div>

			<nav class="flex gap-10">
				<div class="flex flex-col gap-2">
					<p class="font-mono text-caption text-mute uppercase">Product</p>
					<a href="/#ruler" class="hover:text-ink">Ruler tool</a>
					<a href="/#calibrate" class="hover:text-ink">Calibration</a>
					<a href="/faq/" class="hover:text-ink">FAQ</a>
				</div>
				<div class="flex flex-col gap-2">
					<p class="font-mono text-caption text-mute uppercase">Company</p>
					<a href="/about/" class="hover:text-ink">About</a>
					<a href="/privacy/" class="hover:text-ink">Privacy</a>
				</div>
			</nav>
		</div>

		<div class="mt-12 flex flex-col gap-2 border-t border-hairline pt-6 text-caption text-mute md:flex-row md:items-center md:justify-between">
			<p>&copy; {year} Online Ruler Scale.</p>
			<p>No tracking. No account. 100% client-side — your measurements never leave your device.</p>
		</div>
	</div>
</footer>
